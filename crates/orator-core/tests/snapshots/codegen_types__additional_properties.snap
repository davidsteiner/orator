#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
#[serde(deny_unknown_fields)]
pub struct ClosedUser {
    pub id: i32,
    pub name: String,
}
