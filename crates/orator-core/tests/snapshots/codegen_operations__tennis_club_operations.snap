/// List all bookings
#[derive(Debug)]
pub enum ListBookingsResponse {
    /// A list of bookings
    Ok(Vec<Booking>),
    /// Unauthorized
    Unauthorized(Error),
}
pub trait BookingsApi<Ctx = ()>: Send + Sync + 'static {
    type Error: Send;
    /// List all bookings
    fn list_bookings(
        &self,
        ctx: Ctx,
    ) -> impl std::future::Future<
        Output = Result<ListBookingsResponse, Self::Error>,
    > + Send;
}
