#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Error {
    pub code: i32,
    pub message: String,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct NewPet {
    pub name: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub tag: Option<String>,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Pet {
    pub id: i64,
    pub name: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub tag: Option<String>,
}
