#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Address {
    pub street: String,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Person {
    #[serde(skip_serializing_if = "Option::is_none")]
    pub address: Option<Address>,
    pub name: String,
}
