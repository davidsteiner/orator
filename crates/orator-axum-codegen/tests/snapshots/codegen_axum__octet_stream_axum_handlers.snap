    ctx: Ctx,
    body: orator_axum::axum::body::Bytes,
) -> Result<UploadFileResponse, T::Error>
where
    T: DefaultApi<Ctx>,
{
    api.upload_file(ctx, body).await
}
pub fn default_router<T, Ctx>(api: std::sync::Arc<T>) -> orator_axum::axum::Router
where
    T: DefaultApi<Ctx>,
    T::Error: orator_axum::axum::response::IntoResponse,
    Ctx: orator_axum::axum::extract::FromRequestParts<std::sync::Arc<T>> + Send
        + 'static,
