impl orator_axum::axum::response::IntoResponse for DownloadFileResponse {
    fn into_response(self) -> orator_axum::axum::response::Response {
        match self {
            Self::Ok(body) => (orator_axum::http::StatusCode::OK, body).into_response(),
            Self::NotFound => orator_axum::http::StatusCode::NOT_FOUND.into_response(),
        }
    }
}
async fn handle_download_file<T, Ctx>(
    orator_axum::axum::extract::State(
        api,
    ): orator_axum::axum::extract::State<std::sync::Arc<T>>,
    ctx: Ctx,
) -> Result<DownloadFileResponse, T::Error>
where
    T: DefaultApi<Ctx>,
{
    api.download_file(ctx).await
}
impl orator_axum::axum::response::IntoResponse for UploadFileResponse {
    fn into_response(self) -> orator_axum::axum::response::Response {
        match self {
            Self::Ok => orator_axum::http::StatusCode::OK.into_response(),
            Self::BadRequest => {
                orator_axum::http::StatusCode::BAD_REQUEST.into_response()
            }
