impl orator_axum::axum::response::IntoResponse for UploadDocumentResponse {
    fn into_response(self) -> orator_axum::axum::response::Response {
        match self {
            Self::Created(body) => {
                (orator_axum::http::StatusCode::CREATED, orator_axum::axum::Json(body))
                    .into_response()
            }
            Self::BadRequest => {
                orator_axum::http::StatusCode::BAD_REQUEST.into_response()
            }
        }
    }
}
