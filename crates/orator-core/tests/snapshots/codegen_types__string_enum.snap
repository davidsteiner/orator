#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub enum Priority {
    #[serde(rename = "low")]
    Low,
    #[serde(rename = "medium")]
    Medium,
    #[serde(rename = "high")]
    High,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub enum Status {
    #[serde(rename = "active")]
    Active,
    #[serde(rename = "inactive")]
    Inactive,
    #[serde(rename = "pending")]
    Pending,
}
