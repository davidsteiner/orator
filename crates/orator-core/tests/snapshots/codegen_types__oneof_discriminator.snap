#![allow(dead_code, unused_imports, clippy::redundant_field_names)]
use orator_axum::serde;
#[derive(Debug, Clone, PartialEq, serde::Serialize, serde::Deserialize)]
#[serde(crate = "orator_axum::serde")]
pub struct Circle {
    pub radius: f32,
}
#[derive(Debug, Clone, PartialEq, serde::Serialize, serde::Deserialize)]
#[serde(crate = "orator_axum::serde")]
pub struct Rectangle {
    pub height: f32,
    pub width: f32,
}
#[derive(Debug, Clone, PartialEq, serde::Serialize, serde::Deserialize)]
#[serde(crate = "orator_axum::serde")]
#[serde(tag = "type")]
pub enum Shape {
    Circle(Circle),
    Rectangle(Rectangle),
}
