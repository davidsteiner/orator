#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Circle {
    pub radius: f32,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
pub struct Rectangle {
    pub height: f32,
    pub width: f32,
}
#[derive(
    Debug,
    Clone,
    PartialEq,
    orator_axum::serde::Serialize,
    orator_axum::serde::Deserialize
)]
#[serde(crate = "orator_axum::serde")]
#[serde(tag = "type")]
pub enum Shape {
    Circle(Circle),
    Rectangle(Rectangle),
}
