#![allow(dead_code, unused_imports)]
use orator_axum::serde;
/// List items with a default error response (with body)
#[derive(Debug)]
pub enum ListItemsResponse {
    /// A list of items
    Ok(Vec<super::types::Item>),
    /// unexpected error
    Default(orator_axum::http::StatusCode, super::types::Error),
}
/// Delete all items with a default response (no body)
#[derive(Debug)]
pub enum DeleteAllItemsResponse {
    /// Items deleted
    NoContent,
    /// unexpected error
    Default(orator_axum::http::StatusCode),
}
pub trait DefaultApi<Ctx = ()>: Send + Sync + 'static {
    type Error: Send;
    /// List items with a default error response (with body)
    fn list_items(
        &self,
        ctx: Ctx,
    ) -> impl std::future::Future<
        Output = Result<ListItemsResponse, Self::Error>,
    > + Send;
    /// Delete all items with a default response (no body)
    fn delete_all_items(
        &self,
        ctx: Ctx,
    ) -> impl std::future::Future<
        Output = Result<DeleteAllItemsResponse, Self::Error>,
    > + Send;
}
