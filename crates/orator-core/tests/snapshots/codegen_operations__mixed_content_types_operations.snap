/// List items as JSON
#[derive(Debug)]
pub enum ListItemsResponse {
    /// A list of items
    Ok(Vec<Item>),
}
/// Create item via JSON
#[derive(Debug)]
pub enum CreateItemResponse {
    /// Created item
    Created(Item),
}
/// Export items as binary
#[derive(Debug)]
pub enum ExportItemsResponse {
    /// Binary export
    Ok(orator_axum::bytes::Bytes),
}
/// Upload items as a file
#[derive(Debug)]
pub enum ImportItemsResponse {
    /// Import result
    Ok(String),
}
#[derive(Debug)]
pub struct ImportItemsBody {
    pub file: Option<orator_axum::bytes::Bytes>,
}
/// Search with form data
#[derive(Debug)]
pub enum SearchItemsResponse {
    /// Search results
    Ok(Vec<Item>),
}
